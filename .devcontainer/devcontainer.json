{
  "name": "Alauda Dev",
  "image": "build-harbor.alauda.cn/devcontainers/go:1.24",
  "initializeCommand": "",
  "containerEnv": {
    "VSCODE_AGENT_FOLDER": "/workspaces/.vscode-server",
    "CLAUDE_CONFIG_DIR": "/workspaces/.claude",
    "KUBECONFIG": "/workspaces/.kube/config",
    "GOPATH": "/workspaces/.go",
    "GOMODCACHE": "/workspaces/.go/pkg/mod",
    "GOCACHE": "/workspaces/.go/cache",
    "GOPROXY": "https://goproxy.cn,https://build-nexus.alauda.cn/repository/golang,https://build-nexus.alauda.cn/repository/go-proxy-internal,direct",
    "GONOSUMDB": "gitlab-ce.alauda.cn/*,gomod.alauda.cn/*,bitbucket.org/mathildetech/*"
  },
  "remoteEnv": {
    "PATH": "/workspaces/.local/bin:${containerEnv:PATH}"
  },
  "forwardPorts": [8080, 8443],
  "postCreateCommand": "bash .devcontainer/post-create.sh",
  "postStartCommand": "nohup code-server --bind-addr 0.0.0.0:8443 --auth none > /tmp/code-server.log 2>&1 &"
}
